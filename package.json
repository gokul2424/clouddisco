{ "name": "clouddisco", "version": "1.0.0", "description": "Agentic AI Framework for Multi-Cloud Resource Discovery with 3D/2D Architecture Modeling", "private": true, "workspaces": [ "packages/backend", "packages/frontend", "packages/shared", "packages/agents" ], "scripts": { "install-all": "npm install", "dev": "npm run dev --workspaces", "build": "npm run build --workspaces", "test": "npm test --workspaces", "lint": "npm run lint --workspaces", "start:backend": "npm run start --workspace=packages/backend", "start:frontend": "npm run start --workspace=packages/frontend", "start:all": "concurrently \"npm run start:backend\" \"npm run start:frontend\"", "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,md}\"", "clean": "npm run clean --workspaces && rm -rf node_modules" }, "devDependencies": { "concurrently": "^8.2.2", "prettier": "^3.1.0", "typescript": "^5.3.3" }}